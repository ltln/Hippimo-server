datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client-js"
  output       = "prisma.client"
  moduleFormat = "cjs"
  engineType   = "library"
}

// ================= ENUMS =================

enum TransactionStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum NotificationsType {
  BUDGET_WARNING
  ABNORMAL_SPENDING
  SYSTEM
}

enum InsightType {
  HABIT_ANALYSIS
  PREDICTION
  HEALTH_SCORE
}

enum RoleAiChatMess {
  USER
  ASSISTANT
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum UserProvider {
  GMAIL
  GOOGLE
  APPLE
}

// ================= MODELS =================

model User {
  userId    Int      @id @default(autoincrement()) @map("user_id")
  email     String   @unique @db.VarChar(100)
  fullName  String?  @map("full_name") @db.VarChar(50)
  currency  String   @default("VND") @db.VarChar(10)
  provider  UserProvider @default(GOOGLE)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  wallets           Wallet[]
  categories        Category[]
  transactions      Transaction[]
  receipts          Receipt[]
  budgets           Budget[]
  notifications     Notification[]
  financialInsights FinancialInsight[]
  aiChatSessions    AiChatSession[]

  @@map("users")
}

model Wallet {
  walletId  Int      @id @default(autoincrement()) @map("wallet_id")
  userId    Int      @map("user_id")
  name      String   @map("name_wallet") @db.VarChar(50)
  type      String   @db.VarChar(50) // CASH, BANK_ACCOUNT...
  balance   Decimal  @db.Decimal(15, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [userId])
  transactions Transaction[]

  @@map("wallets")
}

model Category {
  categoryId Int            @id @default(autoincrement()) @map("category_id")
  userId     Int            @map("user_id")
  name       String         @db.VarChar(50)
  type       String         @db.VarChar(50) // INCOME, EXPENSE
  icon       String?        @db.VarChar(255)
  color      String?        @db.VarChar(20)
  status     CategoryStatus @default(ACTIVE)

  user         User          @relation(fields: [userId], references: [userId])
  transactions Transaction[] @relation("CategoryToTransaction")
  aiSuggested  Transaction[] @relation("AiSuggestedCategory")
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  transactionId         Int      @id @default(autoincrement()) @map("transaction_id")
  userId                Int      @map("user_id")
  walletId              Int      @map("wallet_id")
  categoryId            Int      @map("category_id")
  amount                Decimal  @db.Decimal(15, 2)
  type                  String   @db.VarChar(20) // INCOME, EXPENSE, TRANSFER
  transactionDate       DateTime @map("transaction_date")
  notes                 String?  @db.Text
  linkedTransactionId   Int?     @map("linked_transaction_id")
  isExcludedFromReport  Boolean  @default(false) @map("is_excluded_from_report")
  aiSuggestedCategoryId Int?     @map("ai_suggested_category_id")
  isEssential           Boolean  @default(false) @map("is_essential")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  user                User      @relation(fields: [userId], references: [userId])
  wallet              Wallet    @relation(fields: [walletId], references: [walletId])
  category            Category  @relation("CategoryToTransaction", fields: [categoryId], references: [categoryId])
  aiSuggestedCategory Category? @relation("AiSuggestedCategory", fields: [aiSuggestedCategoryId], references: [categoryId])

  // Self-relation for Transfer/Refund
  linkedTransaction Transaction?  @relation("TransactionLink", fields: [linkedTransactionId], references: [transactionId])
  childTransactions Transaction[] @relation("TransactionLink")

  receipts      Receipt[]
  notifications Notification[]

  @@map("transactions")
}

model Receipt {
  receiptId         Int               @id @default(autoincrement()) @map("receipt_id")
  userId            Int               @map("user_id")
  transactionId     Int               @map("transaction_id")
  imageUrl          String            @map("image_url") @db.Text
  extractedText     String?           @map("extracted_text") @db.Text
  extractedAmount   Decimal?          @map("extracted_amount") @db.Decimal(15, 2)
  extractedMerchant String?           @map("extracted_merchant") @db.VarChar(100)
  status            TransactionStatus @default(PENDING)
  createdAt         DateTime          @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [userId])
  transaction Transaction @relation(fields: [transactionId], references: [transactionId])

  @@map("receipts")
}

model Budget {
  budgetId              Int     @id @default(autoincrement()) @map("budget_id")
  userId                Int     @map("user_id")
  categoryId            Int     @map("category_id")
  amountLimit           Decimal @map("amount_limit") @db.Decimal(15, 2)
  month                 Int
  year                  Int
  alertThresholdPercent Int     @default(80) @map("alert_threshold_percent")

  user     User     @relation(fields: [userId], references: [userId])
  category Category @relation(fields: [categoryId], references: [categoryId])

  @@map("budgets")
}

model Notification {
  notificationId       Int                @id @default(autoincrement()) @map("notification_id")
  userId               Int                @map("user_id")
  title                String             @db.VarChar(255)
  content              String             @db.Text
  type                 NotificationsType
  status               NotificationStatus @default(UNREAD)
  relatedTransactionId Int?               @map("related_transaction_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [userId])
  transaction Transaction? @relation(fields: [relatedTransactionId], references: [transactionId])

  @@map("notifications")
}

model FinancialInsight {
  financialInsightsId Int         @id @default(autoincrement()) @map("financial_insights_id")
  userId              Int         @map("user_id")
  insightType         InsightType @map("insight_type")
  title               String      @db.VarChar(255)
  content             String      @db.Text
  score               Int?
  predictedAmount     Decimal?    @map("predicted_amount") @db.Decimal(15, 2)
  targetPeriod        String?     @map("target_period") @db.VarChar(50)
  createdAt           DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("financial_insights")
}

model AiChatSession {
  aiChatSessionId Int      @id @default(autoincrement()) @map("ai_chat_session_id")
  userId          Int      @map("user_id")
  title           String   @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [userId])
  messages AiChatMessage[]

  @@map("ai_chat_sessions")
}

model AiChatMessage {
  aiChatMessId Int            @id @default(autoincrement()) @map("ai_chat_mess_id")
  sessionId    Int            @map("session_id")
  role         RoleAiChatMess
  content      String         @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")

  session AiChatSession @relation(fields: [sessionId], references: [aiChatSessionId])

  @@map("ai_chat_messages")
}
